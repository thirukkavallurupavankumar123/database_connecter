# Enterprise GenAI Database Analytics Platform — Backend

# Environment variables (copy to .env and fill in values)
GROQ_API_KEY=your_groq_api_key_here
ENCRYPTION_KEY=your_fernet_key_here
FRONTEND_URL=http://localhost:3000

# --- Database ---
# Local development with SQLite (simple, no setup):
# DATABASE_URL=sqlite:///./argo.db

# Local development with PostgreSQL (via docker-compose):
DATABASE_URL=postgresql://argo_user:argo_pass@localhost:5432/argo_db

# Production PostgreSQL (fill in your server details):
# DATABASE_URL=postgresql://username:password@your-server.com:5432/argo_db

DEBUG=true