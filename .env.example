# ARGO Analytics — Environment Variables
# Copy to .env in the project root (next to docker-compose.yml)

# === Required ===
GROQ_API_KEY=your_groq_api_key_here
ENCRYPTION_KEY=your_fernet_encryption_key_here

# === Database (used by docker-compose) ===
POSTGRES_USER=argo_user
POSTGRES_PASSWORD=argo_pass
POSTGRES_DB=argo_db
DATABASE_URL=postgresql://argo_user:argo_pass@postgres:5432/argo_db
